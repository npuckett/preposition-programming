---
layout: base.njk
permalink: preposition-above-v2.html
loadP5: true
bodyClass: example-v2-body
pageHeader: "Layout prototype"
title: "Above (layout v2)"
description: "Prototype figure-first layout for the Above preposition example — Ink Only technical figure style."
---
{% for prep in prepositions %}
{% if prep.slug == "above" %}
<article class="example-v2">
  <header class="example-v2__masthead">
    <p class="example-v2__category">Spatial relationship</p>
    <h2 class="example-v2__title">{{ prep.title }}</h2>
    <p class="example-v2__lede">{{ prep.tryIt }}</p>
  </header>

  <div class="example-v2__stage">
    <section class="example-v2__figure" aria-labelledby="figure-caption">
      <div class="figure-panel">
        <div class="figure-panel__meta">
          <span class="figure-tag">Fig. 1</span>
          <span id="figure-caption" class="figure-caption">Y-axis height comparison — smaller Y is higher on screen</span>
        </div>
        <div class="figure-panel__canvas">
          <div id="sketch-canvas" class="sketch-canvas sketch-canvas--figure" aria-label="{{ prep.title }} interactive figure"></div>
        </div>
        <p class="figure-panel__try"><strong>Try it</strong> — Drag circles A and B. Watch the Y level lines, Δy dimension, and status bar.</p>
        <a class="editor-cta editor-cta--inline" href="https://editor.p5js.org/{{ site.editorUser }}/sketches/{{ prep.editorSketchId }}" target="_blank" rel="noopener noreferrer">
          <span class="editor-cta__label">Open in p5 Web Editor</span>
          <span class="editor-cta__hint">Fork and experiment with this sketch</span>
        </a>
      </div>
    </section>

    <div class="example-v2__reading">
      <section class="reading-block">
        <h3 class="reading-block__title">Concept</h3>
        <p class="concept-text">{{ prep.conceptHtml | safe }}</p>
      </section>

      <section class="reading-block">
        <h3 class="reading-block__title">Translation strategy</h3>
        {{ prep.strategyHtml | safe }}
      </section>

      <details class="reading-details">
        <summary>Key p5.js methods</summary>
        <div class="reading-details__body">
          {{ prep.methodsHtml | safe }}
        </div>
      </details>

      <details class="reading-details">
        <summary>Code pattern</summary>
        <div class="reading-details__body">
          {{ prep.codeHtml | safe }}
        </div>
      </details>
    </div>
  </div>
</article>

<script type="module">
  import { mountSketch } from '{{ "/js/sketch-host.js" | url }}';
  import createSketch from '{{ "/sketches/above-v2.js" | url }}';
  mountSketch(createSketch, 'sketch-canvas', { maxWidth: 560 });
</script>
{% endif %}
{% endfor %}
