{
  "name": "preposition-programming",
  "version": "2.0.0",
  "description": "Interactive p5.js preposition programming tutorials",
  "scripts": {
    "dev": "eleventy --serve --port=8080",
    "build": "node scripts/build.mjs",
    "extract-manifest": "node scripts/extract-manifest.mjs",
    "editorial": "node scripts/editorial-pass.mjs",
    "export:webeditor": "node scripts/webeditor/export-projects.mjs",
    "generate:webeditor": "node scripts/webeditor/generate-standalone.mjs",
    "serve:cors:webeditor": "npx http-server webeditor -p 8876 --cors -c-1",
    "sync:webeditor": "node scripts/sync-webeditor.mjs",
    "apply:webeditor-links": "node scripts/webeditor/apply-links.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "p5-phone": "^1.11.0"
  }
}
